# =============================================================================
# Environment variables — คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# (.env.local ถูก git ignore — อย่า commit คีย์ลง repo)
# บน Vercel: Project Settings → Environment Variables
#
# อย่าใส่ NODE_ENV ในไฟล์นี้ — Next.js กำหนดเอง (dev/build) การ override อาจทำให้ next build ล้ม
# =============================================================================

# --- จำเป็น: เชื่อม Supabase (ล็อกอิน, ข้อมูล admin, RLS) ---
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- แนะนำบน production: cron สถานะเว็บ + งานเซิร์ฟเวอร์ไม่มี session ---
# Project Settings → API → service_role (ห้ามเปิดให้ client / ห้ามใส่ NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# รหัสที่คุณตั้งเอง (สุ่มยาวๆ) — ป้องกันการเรียก cron โดยไม่ได้รับอนุญาต
# เรียก: GET /api/cron/website-status
# Header: Authorization: Bearer <ค่าเดียวกับ CRON_SECRET>
#
# วิธีให้ "ส่งสถานะเว็บตามเวลา" ทำงานได้แม้ไม่เปิดหน้า web:
# 1) Vercel Cron (พร้อมใช้ — แพลน Pro): มีไฟล์ vercel.json เรียกทุก 5 นาทีแล้ว
#    ตั้ง env นี้บน Vercel → Vercel จะใส่ Authorization: Bearer CRON_SECRET ให้อัตโนมัติ
# 2) External cron ฟรี (แพลน Hobby): cron-job.org / UptimeRobot
#    URL: https://<your-domain>/api/cron/website-status
#    Header: Authorization: Bearer <CRON_SECRET>   (ถี่ทุก 5 นาที)
CRON_SECRET=
